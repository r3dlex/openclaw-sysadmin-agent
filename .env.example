# =============================================================================
# OpenClaw Sysadmin Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env — it contains secrets and local paths.

# --- Paths ---
BACKUP_DRIVE_PATH=/Volumes/MyDrive/backups
OPENCLAW_WORKSPACE=${HOME}/.openclaw/workspace
OPENCLAW_BIN=/opt/homebrew/bin/openclaw
MEMORY_DIR=${HOME}/.openclaw/workspace/memory
ARCHIVE_DIR=${HOME}/.openclaw/workspace/system_maintenance/archive

# --- Gateway ---
OPENCLAW_PORT=18789
OPENCLAW_HEALTH_URL=http://localhost:9080/health

# --- Alerts ---
WHATSAPP_ALERT_NUMBER=+1234567890

# --- Features ---
IPHONE_BACKUP_ENABLED=true
BREW_UPDATE_ENABLED=true

# --- Maintenance ---
ARCHIVE_DAYS_THRESHOLD=30

# --- Inter-Agent Message Queue (IAMQ) ---
IAMQ_AGENT_ID=sysadmin_agent
IAMQ_BASE_URL=http://127.0.0.1:18790

# --- Timezone ---
TZ=Europe/Berlin
